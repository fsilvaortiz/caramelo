{
  "name": "caramelo",
  "displayName": "Caramelo",
  "description": "Visual spec-driven development extension, LLM-agnostic, compatible with GitHub Spec Kit",
  "version": "0.1.3",
  "publisher": "fsilvaortiz",
  "license": "MIT",
  "icon": "resources/icons/caramelo-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/fsilvaortiz/caramelo"
  },
  "homepage": "https://github.com/fsilvaortiz/caramelo#readme",
  "bugs": {
    "url": "https://github.com/fsilvaortiz/caramelo/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "keywords": [
    "spec-driven-development",
    "spec-kit",
    "llm",
    "ai",
    "specification",
    "planning",
    "ollama",
    "claude",
    "openai",
    "gemini",
    "copilot",
    "jira"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:caramelo.workflow",
    "workspaceContains:.specify"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "caramelo",
          "title": "Caramelo",
          "icon": "resources/icons/caramelo_activity_bar.svg"
        }
      ]
    },
    "views": {
      "caramelo": [
        {
          "id": "caramelo.providers",
          "type": "webview",
          "name": "Providers",
          "visibility": "collapsed"
        },
        {
          "id": "caramelo.workflow",
          "type": "webview",
          "name": "Workflow",
          "visibility": "visible"
        }
      ]
    },
    "submenus": [
      {
        "id": "caramelo.editorMenu",
        "label": "Caramelo",
        "icon": {
          "dark": "resources/icons/caramelo-menu-dark.svg",
          "light": "resources/icons/caramelo-menu-light.svg"
        }
      }
    ],
    "commands": [
      {
        "command": "caramelo.newSpec",
        "title": "Caramelo: New Spec",
        "icon": "$(add)"
      },
      {
        "command": "caramelo.selectProvider",
        "title": "Caramelo: Select Provider"
      },
      {
        "command": "caramelo.addProvider",
        "title": "Caramelo: Add Provider",
        "icon": "$(add)"
      },
      {
        "command": "caramelo.editConstitution",
        "title": "Caramelo: Edit Constitution",
        "icon": "$(edit)"
      },
      {
        "command": "caramelo.startTask",
        "title": "Caramelo: Start Task"
      },
      {
        "command": "caramelo.runPhase",
        "title": "Caramelo: Generate Phase",
        "icon": "$(play)"
      },
      {
        "command": "caramelo.approvePhase",
        "title": "Caramelo: Approve Phase",
        "icon": "$(check)"
      },
      {
        "command": "caramelo.regeneratePhase",
        "title": "Caramelo: Regenerate Phase"
      },
      {
        "command": "caramelo.syncTemplates",
        "title": "Caramelo: Sync Spec Kit Templates"
      },
      {
        "command": "caramelo.viewChanges",
        "title": "Caramelo: View Changes"
      },
      {
        "command": "caramelo.previewSpec",
        "title": "Caramelo: Preview Spec"
      },
      {
        "command": "caramelo.approvePhaseFromEditor",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "caramelo.regeneratePhaseFromEditor",
        "title": "Regenerate",
        "icon": "$(sync)"
      },
      {
        "command": "caramelo.nextPhaseFromEditor",
        "title": "Next Phase",
        "icon": "$(arrow-right)"
      },
      {
        "command": "caramelo.runNextTaskFromEditor",
        "title": "Run Next Task",
        "icon": "$(play)"
      },
      {
        "command": "caramelo.runAllTasks",
        "title": "Run All Tasks",
        "icon": "$(run-all)"
      },
      {
        "command": "caramelo.openDag",
        "title": "Caramelo: Workflow Map",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "caramelo.createSpecFromJira",
        "title": "Caramelo: Create Spec from Jira",
        "icon": "$(cloud-download)"
      },
      {
        "command": "caramelo.clarify",
        "title": "Clarify Spec",
        "icon": "$(question)"
      },
      {
        "command": "caramelo.analyze",
        "title": "Analyze Consistency",
        "icon": "$(search)"
      },
      {
        "command": "caramelo.generateChecklist",
        "title": "Generate Checklist",
        "icon": "$(checklist)"
      },
      {
        "command": "caramelo.editProvider",
        "title": "Edit Provider",
        "icon": "$(edit)"
      },
      {
        "command": "caramelo.deleteProvider",
        "title": "Delete Provider",
        "icon": "$(trash)"
      },
      {
        "command": "caramelo.testProvider",
        "title": "Test Connection",
        "icon": "$(debug-start)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "caramelo.openDag",
          "when": "view == caramelo.workflow",
          "group": "navigation"
        }
      ],
      "view/item/context": [],
      "editor/title": [
        {
          "submenu": "caramelo.editorMenu",
          "when": "caramelo.editorPhaseStatus || caramelo.editorHasPendingTasks",
          "group": "navigation"
        }
      ],
      "caramelo.editorMenu": [
        {
          "command": "caramelo.approvePhaseFromEditor",
          "when": "caramelo.editorPhaseStatus == pending-approval",
          "group": "1_phase@1"
        },
        {
          "command": "caramelo.regeneratePhaseFromEditor",
          "when": "caramelo.editorPhaseStatus == pending-approval || caramelo.editorPhaseStatus == approved || caramelo.editorPhaseStatus == stale",
          "group": "1_phase@2"
        },
        {
          "command": "caramelo.nextPhaseFromEditor",
          "when": "caramelo.editorHasNextPhase",
          "group": "1_phase@3"
        },
        {
          "command": "caramelo.runNextTaskFromEditor",
          "when": "caramelo.editorHasPendingTasks",
          "group": "2_tasks@1"
        },
        {
          "command": "caramelo.runAllTasks",
          "when": "caramelo.editorHasPendingTasks",
          "group": "2_tasks@2"
        },
        {
          "command": "caramelo.clarify",
          "when": "caramelo.editorIsRequirements",
          "group": "3_quality@1"
        },
        {
          "command": "caramelo.analyze",
          "when": "caramelo.editorHasMultiplePhases",
          "group": "3_quality@2"
        },
        {
          "command": "caramelo.generateChecklist",
          "when": "caramelo.editorPhaseStatus == pending-approval || caramelo.editorPhaseStatus == approved",
          "group": "3_quality@3"
        }
      ]
    },
    "configuration": {
      "title": "Caramelo",
      "properties": {
        "caramelo.providers": {
          "type": "array",
          "default": [],
          "description": "Configured LLM providers",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique provider identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "type": {
                "type": "string",
                "enum": [
                  "openai-compatible",
                  "anthropic"
                ],
                "description": "Provider API type"
              },
              "endpoint": {
                "type": "string",
                "description": "Base URL for the provider API"
              },
              "model": {
                "type": "string",
                "description": "Model identifier"
              },
              "authHeader": {
                "type": "string",
                "pattern": "^[A-Za-z0-9-]+$",
                "maxLength": 64,
                "description": "HTTP header name used to send the API key (e.g. Authorization, x-api-key). Letters, digits and hyphens only."
              },
              "authPrefix": {
                "type": "string",
                "pattern": "^[A-Za-z0-9-]*$",
                "maxLength": 16,
                "description": "Value prefix prepended to the API key (e.g. Bearer, Basic). Leave empty to send the raw key."
              }
            },
            "required": [
              "id",
              "name",
              "type",
              "endpoint",
              "model"
            ]
          }
        },
        "caramelo.activeProvider": {
          "type": "string",
          "default": "",
          "description": "ID of the currently active LLM provider"
        },
        "caramelo.sse.timeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 5000,
          "description": "Maximum time (ms) to wait for a single chunk of streaming output from the LLM before aborting. Raise this if you run slow local models."
        },
        "caramelo.tasks.allowWithoutGit": {
          "type": "boolean",
          "default": false,
          "description": "Skip the 'no backup available' confirmation when running tasks in workspaces that are not git repositories. Leave false for safety; enable it only when you intentionally use Caramelo in non-versioned folders."
        },
        "caramelo.autoApplyEdits": {
          "type": "boolean",
          "default": false,
          "description": "When true, task edits are written to disk without a diff preview or confirmation dialog. Leave this off unless you have a reliable git safety net — Caramelo creates one automatically when the workspace is a git repo."
        },
        "caramelo.useAgentLoop": {
          "type": "boolean",
          "default": true,
          "description": "Run tasks via a tool-calling agent loop (file_read / file_edit / grep / bash / …) when the active provider supports it. When false, Caramelo falls back to the legacy single-shot SEARCH/REPLACE text protocol. Leave this on unless you need to debug regressions against the legacy path."
        },
        "caramelo.enableBashTool": {
          "type": "boolean",
          "default": true,
          "description": "Expose a bash/exec tool to the agent. Every bash call requires an explicit approval prompt that shows the literal command. Disable to remove bash entirely from the tool list advertised to the model."
        },
        "caramelo.agent.maxIterations": {
          "type": "number",
          "default": 15,
          "minimum": 3,
          "maximum": 50,
          "description": "Maximum number of agent turns per task. The agent stops after this many tool-calling rounds to avoid runaway loops on ambiguous tasks."
        },
        "caramelo.agent.approval": {
          "type": "string",
          "enum": [
            "auto-reads-batched-writes",
            "per-call",
            "auto-all"
          ],
          "default": "auto-reads-batched-writes",
          "description": "How write/bash tool calls are approved. auto-reads-batched-writes: reads auto-run, bash always prompts, writes are batched per turn. per-call: every non-read prompts individually. auto-all: no prompts — relies on the git safety stash to recover."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Specs can be browsed but LLM execution is blocked in untrusted workspaces"
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "compile-tests": "tsc -p tsconfig.test.json",
    "pretest:smoke": "npm run compile-tests && npm run build",
    "test:smoke": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "mocha": "^11.7.5",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
